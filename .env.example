# Database (Supabase transaction pooler URL for production)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# NextAuth
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET=""   # openssl rand -base64 32

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend email (resend.com)
RESEND_API_KEY=""
EMAIL_FROM="noreply@agentmatch.ai"

# Admin & Cron (generate random secrets)
ADMIN_SECRET=""      # openssl rand -base64 16
CRON_SECRET=""       # openssl rand -base64 16
